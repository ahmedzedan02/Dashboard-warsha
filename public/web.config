<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Allow serving static files from the /assets folder -->
    <staticContent>
      <mimeMap fileExtension=".js"   mimeType="application/javascript" />
      <mimeMap fileExtension=".mjs"  mimeType="application/javascript" />
      <mimeMap fileExtension=".css"  mimeType="text/css" />
      <mimeMap fileExtension=".svg"  mimeType="image/svg+xml" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>

    <!-- SPA fallback: all routes → index.html -->
    <rewrite>
      <rules>
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Do NOT rewrite requests for actual files -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <!-- Do NOT rewrite requests for actual directories -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory"  negate="true" />
            <!-- Do NOT rewrite API requests -->
            <add input="{REQUEST_URI}" pattern="^/api/"             negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <!-- Enable GZip + Brotli compression -->
    <httpCompression>
      <dynamicTypes>
        <add enabled="true" mimeType="application/javascript" />
        <add enabled="true" mimeType="text/css" />
        <add enabled="true" mimeType="application/json" />
        <add enabled="true" mimeType="text/html" />
      </dynamicTypes>
      <staticTypes>
        <add enabled="true" mimeType="application/javascript" />
        <add enabled="true" mimeType="text/css" />
        <add enabled="true" mimeType="application/json" />
      </staticTypes>
    </httpCompression>

    <!-- Browser caching for hashed assets (1 year) -->
    <caching>
      <profiles>
        <add extension=".js"   policy="CacheForTimePeriod" kernelCachePolicy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".css"  policy="CacheForTimePeriod" kernelCachePolicy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".woff" policy="CacheForTimePeriod" kernelCachePolicy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".woff2" policy="CacheForTimePeriod" kernelCachePolicy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".svg"  policy="CacheForTimePeriod" kernelCachePolicy="CacheForTimePeriod" duration="365.00:00:00" />
        <add extension=".webp" policy="CacheForTimePeriod" kernelCachePolicy="CacheForTimePeriod" duration="365.00:00:00" />
        <!-- index.html should NEVER be cached -->
        <add extension=".html" policy="DisableCache" kernelCachePolicy="DisableCache" />
      </profiles>
    </caching>

    <!-- Prevent directory listing -->
    <directoryBrowse enabled="false" />

    <!-- Custom error pages -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" />
      <error statusCode="404" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>

  </system.webServer>
</configuration>
